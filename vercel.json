{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/inspection/:shareId", "destination": "/api/inspection-view?shareId=:shareId" }
  ],
  "redirects": [
    { "source": "/case/003", "destination": "/case/003.html", "permanent": true },
    { "source": "/case/005", "destination": "/case/005.html", "permanent": true },
    { "source": "/case/013", "destination": "/case/013.html", "permanent": true },
    { "source": "/case/018", "destination": "/case/018.html", "permanent": true },
    { "source": "/case/021", "destination": "/case/021.html", "permanent": true },
    { "source": "/challenge", "destination": "/challenge.html", "permanent": true },
    { "source": "/independence", "destination": "/independence.html", "permanent": true },
    { "source": "/whitepaper", "destination": "/whitepaper.html", "permanent": true },
    { "source": "/retention", "destination": "/retention.html", "permanent": true },
    { "source": "/publication-policy", "destination": "/publication-policy.html", "permanent": true },
    { "source": "/glossary", "destination": "/glossary.html", "permanent": true },
    { "source": "/methodology", "destination": "/methodology.html", "permanent": true },
    { "source": "/workbench", "destination": "/workbench.html", "permanent": true },
    { "source": "/archive", "destination": "/archive.html", "permanent": true },
    { "source": "/volunteer-gap", "destination": "/volunteer-gap.html", "permanent": true },
    { "source": "/for-readers", "destination": "/for-readers.html", "permanent": true },
    { "source": "/how-it-works", "destination": "/how-it-works.html", "permanent": true },
    { "source": "/faq", "destination": "/faq.html", "permanent": true },
    { "source": "/contact", "destination": "/contact.html", "permanent": true },
    { "source": "/challenge-log", "destination": "/challenge-log.html", "permanent": true },
    { "source": "/calibration", "destination": "/calibration.html", "permanent": true },
    { "source": "/briefing", "destination": "/field-notes/", "permanent": true },
    { "source": "/briefing/", "destination": "/field-notes/", "permanent": true },
    { "source": "/briefing/post-1", "destination": "/field-notes/", "permanent": true },
    { "source": "/briefing/post-1/", "destination": "/field-notes/", "permanent": true },
    { "source": "/briefing/post-2", "destination": "/field-notes/", "permanent": true },
    { "source": "/briefing/post-2/", "destination": "/field-notes/", "permanent": true },
    { "source": "/briefing/post-3", "destination": "/field-notes/", "permanent": true },
    { "source": "/briefing/post-3/", "destination": "/field-notes/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/workbench.html",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://vitals.vercel-insights.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" }
      ]
    },
    {
      "source": "/((?!workbench\\.html).*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://vitals.vercel-insights.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" }
      ]
    }
  ]
}
